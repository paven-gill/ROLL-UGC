# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apify — get this from apify.com > Settings > Integrations
APIFY_API_TOKEN=your-apify-token

# A secret string you make up — used to protect the sync endpoint
CRON_SECRET=make-up-any-long-random-string
