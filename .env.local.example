# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apify — get this from apify.com > Settings > Integrations
APIFY_API_TOKEN=your-apify-token

# A secret string you make up — used to protect the sync endpoint
CRON_SECRET=make-up-any-long-random-string

# Wise — get API token from wise.com > Settings > API tokens
# Set WISE_SANDBOX=true while testing, remove or set false for production
WISE_API_TOKEN=your-wise-api-token
WISE_SANDBOX=true
