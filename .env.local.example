# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RapidAPI — one key powers both Instagram (Looter2) and TikTok (ScrapTik)
RAPIDAPI_KEY=your-rapidapi-key

# TikTok scraper selector: "scraptik" (RapidAPI) or "apify" (legacy). Defaults to
# "apify" if unset. Flip to scraptik once the /api/sync/tiktok/test numbers match.
TIKTOK_SCRAPER=scraptik

# How many recent posts to pull per creator (90 ≈ last 3 months, 180 ≈ 6 months)
TIKTOK_POSTS_LIMIT=90

# How often the cron actually runs TikTok (1 = every night)
TIKTOK_SYNC_EVERY_DAYS=1

# Apify — legacy TikTok scraper. Only needed while TIKTOK_SCRAPER=apify.
APIFY_API_TOKEN=your-apify-token

# A secret string you make up — used to protect the sync endpoint
CRON_SECRET=make-up-any-long-random-string

# Wise — get API token from wise.com > Settings > API tokens
# Set WISE_SANDBOX=true while testing, remove or set false for production
WISE_API_TOKEN=your-wise-api-token
WISE_SANDBOX=true
